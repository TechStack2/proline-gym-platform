# Proline Gym Platform — Environment Variables
# ======================================================
# Copy to .env.local: cp .env.local.example .env.local
# .env.local is gitignored — never committed

NEXT_PUBLIC_SUPABASE_URL=https://ufpuebfkcpohwubrutff.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_YOUR_ANON_KEY

# Locale
NEXT_PUBLIC_DEFAULT_LOCALE=ar
NEXT_PUBLIC_SUPPORTED_LOCALES=ar,en,fr

# Feature flags
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_CAMPS_MODULE=true
NEXT_PUBLIC_ENABLE_COACH_RENTALS=true
NEXT_PUBLIC_ENABLE_WHATSAPP_INTEGRATION=false

# WhatsApp Cloud API (optional)
WHATSAPP_API_VERSION=v19.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=proline-gym-webhook-verify

# Twilio SMS fallback (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

NEXT_PUBLIC_APP_NAME=Proline Gym
NEXT_PUBLIC_APP_URL=http://localhost:3000
